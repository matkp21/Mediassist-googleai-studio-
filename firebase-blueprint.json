{
  "entities": {
    "ClinicalGuideline": {
      "title": "Clinical Guideline",
      "description": "Evidence-based clinical protocol or guideline document.",
      "type": "object",
      "properties": {
        "documentText": { "type": "string" },
        "specialtyField": { "type": "string" },
        "embedding": { "type": "array", "description": "Vector embedding for semantic search" },
        "source": { "type": "string" }
      },
      "required": ["documentText", "specialtyField"]
    },
    "PatientFact": {
      "title": "Patient Fact",
      "description": "A discrete, medically relevant fact about a patient's health or history.",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["symptom", "medication_adherence", "lifestyle", "preference", "allergy"] },
        "fact": { "type": "string" },
        "clinicalRelevance": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "fact", "clinicalRelevance", "timestamp"]
    },
    "PatientLabs": {
      "title": "Patient Laboratory Result",
      "description": "Structured lab results for a patient.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Lab abbreviation (CMP, CBC, etc.)" },
        "values": { "type": "object", "description": "Map of lab component to result" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["type", "values", "date", "status"]
    },
    "GPProtocol": {
      "title": "GP Note Protocol",
      "description": "Structured clinical GP note for OPD quick reference.",
      "type": "object",
      "properties": {
        "condition": { "type": "string" },
        "setting": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "criteria": { "type": "string" },
        "rx_lines": { "type": "array" },
        "adjuncts": { "type": "array", "items": { "type": "string" } },
        "investigations": { "type": "array", "items": { "type": "string" } },
        "peds_dosing": { "type": "object" }
      },
      "required": ["condition", "setting"]
    }
  },
  "firestore": {
    "/gp_protocols/{protocolId}": {
      "schema": "GPProtocol",
      "description": "Deterministic knowledge graph for standard prescriptions."
    },
    "/clinical_guidelines/{guidelineId}": {
      "schema": "ClinicalGuideline",
      "description": "Knowledge hub for RAG guidelines."
    },
    "/patients/{patientId}": {
      "schema": {
        "type": "object",
        "properties": {
          "clinicalSummary": { "type": "string" },
          "lastInteraction": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Core patient profile with summary digest."
    },
    "/patients/{patientId}/memory_facts/{factId}": {
      "schema": "PatientFact",
      "description": "Continuous persistent memory for a patient."
    },
    "/patients/{patientId}/labs/{labId}": {
      "schema": "PatientLabs",
      "description": "Structured laboratory history."
    },
    "/lectures/{lectureId}": {
      "schema": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "duration": { "type": "number" },
              "status": { "type": "string", "enum": ["live", "processing", "completed"] }
            }
          },
          "outputs": {
            "type": "object",
            "properties": {
              "finalSummary": { "type": "string" },
              "markdownNotes": { "type": "string" },
              "mermaidMindMap": { "type": "string" }
            }
          }
        }
      },
      "description": "Master lecture container with metadata and final outputs."
    },
    "/lectures/{lectureId}/chunks/{chunkId}": {
      "schema": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "number" },
          "rawTranscript": { "type": "string" },
          "correctedTranscript": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } }
        }
      },
      "description": "Atomic 30-60s audio transcription chunks."
    },
    "/lectures/{lectureId}/slides/{slideId}": {
      "schema": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "number" },
          "imageUrl": { "type": "string" },
          "ocrText": { "type": "string" },
          "diagramAnalysis": { "type": "string" }
        }
      },
      "description": "Visual slide context captured during the lecture."
    },
    "/lectures/{lectureId}/assessments/{assessmentId}": {
      "schema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["mcq", "flashcard"] },
          "content": { "type": "object" }
        }
      },
      "description": "AI-generated quiz and flashcard materials."
    }
  }
}
